# Caddy reverse proxy + automatic Let's Encrypt for Nakama,
# Grafana, and the WebRTC/WS signaling proxy.
{
	email admin@snoringcat.games
	# Load global rate-limit zones (see github.com/mholt/caddy-ratelimit).
	order rate_limit before basicauth
	# Bind the admin/metrics endpoint to the container's
	# Docker-internal interface so Prometheus (sibling
	# container) can scrape `/metrics`. The Cloud firewall
	# blocks 2019/tcp from the public internet; only
	# nakama-net peers can reach it. Default `localhost:2019`
	# is unreachable from other containers (lo isn't shared
	# across docker-network namespaces).
	admin 0.0.0.0:2019
}

# Structured JSON access log shared by every site block. Written to
# a host-bind-mounted path (see docker-compose caddy volumes) so the
# caddy-access-analytics job can read it over SSH. Caddy's json
# encoder emits ts (epoch float), duration, status, and request.uri,
# which is exactly what that job parses. Rolled to keep disk bounded.
(accesslog) {
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 5
			roll_keep_for 336h
		}
		format json
	}
}

nakama.snoringcat.games {
	import accesslog
	encode gzip

	# Per-IP rate limit on the unauthenticated authentication
	# endpoints. 30 attempts per IP per 5 min is generous for
	# legit (typo-and-retry) flows but kills brute-force quickly.
	# Returns 429 with a Retry-After header.
	@auth_endpoints path /v2/account/authenticate*
	rate_limit @auth_endpoints {
		zone authenticate {
			key {remote_host}
			events 30
			window 5m
		}
	}

	# Nakama HTTP API + WebSocket realtime endpoint (/ws).
	# flush_interval -1 disables response buffering — required for
	# low-latency realtime traffic.
	reverse_proxy nakama:7350 {
		flush_interval -1
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

# Grafana UI fronted by Caddy TLS. Restored 2026-05-13 in
# Stage 7.11 (lightweight obs re-introduction). Auth handled
# by Grafana itself (admin user provisioned via env in the
# compose; password is GRAFANA_ADMIN_PASSWORD in
# /opt/nakama/.env).
grafana.snoringcat.games {
	import accesslog
	encode gzip

	reverse_proxy grafana:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

# WebSocket signaling proxy. Stable hostname in front of the
# dynamic Edgegap deploy. Caddy terminates TLS once;
# signaling-proxy validates the HMAC token in the URL and
# bridges to the upstream game-server. See
# infra/remote/signaling-proxy/main.go for the protocol. The
# upstream is a sibling docker-compose service on the same
# nakama-net network; reachable via the service's DNS name.
signaling.snoringcat.games {
	import accesslog
	encode gzip

	reverse_proxy signaling-proxy:4435 {
		flush_interval -1
		# WebSocket upgrade is automatic in Caddy 2.
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}
