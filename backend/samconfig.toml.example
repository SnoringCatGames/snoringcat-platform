# Copy this file to samconfig.toml and fill in your values.
# samconfig.toml is gitignored to prevent committing secrets.
#
# Most overrides are also passable via the CLI flags on
# scripts/deploy.ps1, which pre-fills stack_name, profile, and
# region. samconfig.toml is mainly useful for AlertEmail (which
# is intentionally not a deploy.ps1 flag because it changes
# rarely and contains an email address).

version = 0.1

[default.deploy.parameters]
stack_name = "snoringcat-platform-backend"
region = "us-west-2"
capabilities = "CAPABILITY_IAM"
# Empty AlertEmail disables the SNS email subscription. Fill it
# in to receive alarm notifications.
parameter_overrides = [
    "DefaultGameId=hopnbop",
    "SteamAppID=",
    "AlertEmail=",
    "MatchmakingConfigName=hopnbop-ffa-matchmaker"
]
